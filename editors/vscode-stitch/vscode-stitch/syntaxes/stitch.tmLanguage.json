{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Stitch",
  "scopeName": "source.stitch",
  "patterns": [
    { "include": "#comments" },
    { "include": "#expression" }
  ],
  "repository": {
    "expression": {
      "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#booleans" },
        { "include": "#keywords" },
        { "include": "#placeholders" },
        { "include": "#receiver" },
        { "include": "#types" },
        { "include": "#function-call" },
        { "include": "#operators" },
        { "include": "#member" }
      ]
    },

    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.stitch",
          "begin": "//",
          "end": "$"
        },
        { "include": "#block-comment" }
      ]
    },
    "block-comment": {
      "name": "comment.block.stitch",
      "begin": "/\\*",
      "end": "\\*/",
      "patterns": [
        { "include": "#block-comment" }
      ]
    },

    "strings": {
      "name": "string.quoted.double.stitch",
      "begin": "\"",
      "end": "\"",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.string.begin.stitch" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.stitch" }
      },
      "patterns": [
        {
          "name": "constant.character.escape.stitch",
          "match": "\\\\[nt\"\\\\]"
        },
        {
          "comment": "{{ and }} are literal braces, not interpolation",
          "name": "constant.character.escape.stitch",
          "match": "\\{\\{|\\}\\}"
        },
        {
          "name": "meta.interpolation.stitch",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.section.interpolation.begin.stitch" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.section.interpolation.end.stitch" }
          },
          "patterns": [
            { "include": "#expression" }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.stitch",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*\\b"
        },
        {
          "name": "constant.numeric.integer.stitch",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },

    "booleans": {
      "name": "constant.language.boolean.stitch",
      "match": "\\b(true|false)\\b"
    },

    "keywords": {
      "patterns": [
        {
          "comment": "type- and behavior-defining declarations",
          "name": "storage.type.stitch",
          "match": "\\b(prod|sum|contract|on)\\b"
        },
        {
          "name": "storage.modifier.stitch",
          "match": "\\b(mut|free)\\b"
        },
        {
          "comment": "and/or/not are word operators",
          "name": "keyword.operator.word.stitch",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "keyword.control.stitch",
          "match": "\\b(match|if|let|use|uses)\\b"
        }
      ]
    },

    "placeholders": {
      "comment": "lambda placeholders: $ (bare) and $name",
      "name": "variable.parameter.placeholder.stitch",
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*|\\$"
    },

    "receiver": {
      "comment": "@field receiver access inside `on` blocks",
      "name": "variable.other.member.stitch",
      "match": "@[A-Za-z_][A-Za-z0-9_]*|@"
    },

    "types": {
      "comment": "Capitalized identifiers are types and constructors",
      "name": "entity.name.type.stitch",
      "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
    },

    "function-call": {
      "comment": "lowercase identifier immediately before ( — definition or call",
      "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.stitch" }
      }
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.stitch",
          "match": "->|=>|<-|\\|>|\\?\\.|==|!=|<=|>=|\\.\\.=|\\.\\."
        },
        {
          "name": "keyword.operator.stitch",
          "match": "[+\\-*/%<>=|?]"
        }
      ]
    },

    "member": {
      "comment": "field/method access after a dot; included after #operators so .. and ?. win first",
      "patterns": [
        {
          "comment": "method call: .name(",
          "match": "\\.([a-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": { "name": "entity.name.function.stitch" }
          }
        },
        {
          "comment": "field access: .name",
          "match": "\\.([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "variable.other.property.stitch" }
          }
        }
      ]
    }
  }
}
