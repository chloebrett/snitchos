    {
      "id": 6,
      "type": "table",
      "title": "Stitch traces \u2014 click a row for the span tree",
      "description": "TraceQL over Tempo: every stitch.eval bracketing a loaded program's spans (primes.compute / analyze), plus the boot self-test. The whole point \u2014 a Stitch program's execution in the same Grafana as the kernel it runs on. Run workload=stitch-fs, then `:load primes.st` and `primes(25)`.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ name =~ \"stitch.*|primes.*|analyze.*\" }",
          "limit": 20,
          "tableType": "traces"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
