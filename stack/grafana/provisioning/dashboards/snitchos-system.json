{
  "tags": [
    "snitchos"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "title": "SnitchOS \u2014 System",
  "uid": "snitchos-system",
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heartbeat count",
      "description": "Monotonically incrementing counter of kernel heartbeats.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_heartbeat_count",
          "legendFormat": "heartbeats",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 3
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Strings in intern table",
      "description": "Number of strings registered with the kernel's intern table.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_intern_strings_used",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 56,
                "color": "orange"
              },
              {
                "value": 64,
                "color": "red"
              }
            ]
          },
          "min": 0,
          "max": 64
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Time CSR (ticks)",
      "description": "Latest read of the RISC-V time CSR. Useful for confirming the kernel is still running.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_time_ticks",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Heartbeat rate (per second)",
      "description": "Derivative of the heartbeat counter. Should hover around 1 if the kernel is heartbeating once per timebase second.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_heartbeat_count[1m])",
          "legendFormat": "heartbeats/sec",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent kernel spans",
      "description": "Spans emitted by the kernel in the current time range. Click a trace ID to open the full trace view.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"snitchos\" }",
          "limit": 20,
          "tableType": "traces"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Timer IRQ duration (percentiles)",
      "description": "p50, p95, p99 of the timer IRQ handler duration, in cycle counter ticks. Derived from the snitchos.irq.timer.duration_ticks histogram (one observation per heartbeat).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, rate(snitchos_irq_timer_duration_ticks_bucket[1m]))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(snitchos_irq_timer_duration_ticks_bucket[1m]))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(snitchos_irq_timer_duration_ticks_bucket[1m]))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 3
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    }
  ]
}