{
  "tags": [
    "snitchos"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "title": "SnitchOS \u2014 System",
  "uid": "snitchos-system",
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Heartbeat count",
      "description": "Monotonically incrementing counter of kernel heartbeats.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_heartbeat_count",
          "legendFormat": "heartbeats",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 3
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Strings in intern table",
      "description": "Number of strings registered with the kernel's intern table.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_intern_strings_used",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "green"
              },
              {
                "value": 56,
                "color": "orange"
              },
              {
                "value": 64,
                "color": "red"
              }
            ]
          },
          "min": 0,
          "max": 64
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Time CSR (ticks)",
      "description": "Latest read of the RISC-V time CSR. Useful for confirming the kernel is still running.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_time_ticks",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "value": null,
                "color": "blue"
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "graphMode": "area",
        "colorMode": "value",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Heartbeat rate (per second)",
      "description": "Derivative of the heartbeat counter. Should hover around 1 if the kernel is heartbeating once per timebase second.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_heartbeat_count[1m])",
          "legendFormat": "heartbeats/sec",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 5,
      "type": "table",
      "title": "Recent kernel spans",
      "description": "Spans emitted by the kernel in the current time range. Click a trace ID to open the full trace view.",
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "queryType": "traceql",
          "query": "{ resource.service.name = \"snitchos\" }",
          "limit": 20,
          "tableType": "traces"
        }
      ],
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Timer IRQ duration (percentiles)",
      "description": "p50, p95, p99 of the timer IRQ handler duration, in cycle counter ticks. Derived from the snitchos.irq.timer.duration_ticks histogram (one observation per heartbeat).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, rate(snitchos_irq_timer_duration_ticks_bucket[1m]))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(snitchos_irq_timer_duration_ticks_bucket[1m]))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(snitchos_irq_timer_duration_ticks_bucket[1m]))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 3
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Harts online",
      "description": "Build-time hart-count cap (MAX_HARTS). v0.6 step 8 brought this from 1 to 2; v0.6 step 10 will start scheduling tasks onto the secondary.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 24 },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_smp_harts_total",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Boot hart mhartid",
      "description": "Platform hart id OpenSBI handed kmain as the boot hart (the value of `a0` at kmain entry). Under QEMU -smp 2 this is not deterministic: OpenSBI picks 0 or 1 across boots. Useful for correlating logs with the boot hart's identity.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_smp_boot_hart_id",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": null } ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Secondary hart wfi rate",
      "description": "How often hart 1 has woken from `wfi` and looped. v0.6 step 8: hart 1 has no work, so the rate is whatever stray interrupts QEMU delivers (typically near zero). v0.6 step 10 will give hart 1 a runqueue + idle task, and this will jump to a steady rate as scheduling decisions wake it via IPI.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_smp_secondary_wfi_total[1m])",
          "legendFormat": "wfi wakeups/s",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "snitchos_smp_secondary_wfi_total",
          "legendFormat": "cumulative (right axis)",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "cumulative (right axis)" },
            "properties": [ { "id": "custom.axisPlacement", "value": "right" } ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}