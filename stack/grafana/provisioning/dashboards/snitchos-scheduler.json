{
  "tags": [
    "snitchos"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "title": "SnitchOS \u2014 Scheduler",
  "uid": "snitchos-scheduler",
  "id": null,
  "panels": [
    {
      "id": 37,
      "type": "timeseries",
      "title": "Active threads (idle excluded)",
      "description": "Per-task CPU time rate excluding idle's `wfi`-dominated band. Use this to see relative work between non-idle threads when idle would otherwise drown them out.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_task_main_cpu_time_ticks[30s])",
          "legendFormat": "main",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "rate(snitchos_task_task_a_cpu_time_ticks[30s])",
          "legendFormat": "task_a",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "C",
          "expr": "rate(snitchos_task_task_b_cpu_time_ticks[30s])",
          "legendFormat": "task_b",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 30,
      "type": "timeseries",
      "title": "Thread timeline (CPU time share)",
      "description": "Per-task on-CPU time rate, stacked. Width of each band shows that thread's recent CPU share. Sum equals wallclock when the scheduler is fully utilising the CPU; idle's band absorbs whatever's left.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_task_main_cpu_time_ticks[30s])",
          "legendFormat": "main",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "rate(snitchos_task_idle_cpu_time_ticks[30s])",
          "legendFormat": "idle",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "C",
          "expr": "rate(snitchos_task_task_a_cpu_time_ticks[30s])",
          "legendFormat": "task_a",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "D",
          "expr": "rate(snitchos_task_task_b_cpu_time_ticks[30s])",
          "legendFormat": "task_b",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Context switches per second",
      "description": "Derivative of `snitchos.sched.context_switches_total`. With 4 tasks cooperative-yielding tightly, expect hundreds to thousands per second.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_sched_context_switches_total[30s])",
          "legendFormat": "switches/s",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Yield overhead (ticks, percentiles)",
      "description": "Time spent in `yield_now`'s bookkeeping path: lock acquisition + runqueue manipulation + ContextSwitch frame emission. Does NOT include the asm itself or time off-CPU.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, rate(snitchos_sched_yield_overhead_ticks_bucket[1m]))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, rate(snitchos_sched_yield_overhead_ticks_bucket[1m]))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, rate(snitchos_sched_yield_overhead_ticks_bucket[1m]))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 33,
      "type": "timeseries",
      "title": "Per-thread scheduling rate (runs/sec)",
      "description": "How often each task is picked off the runqueue, per second. In strict round-robin with N runnable tasks, all of them track at ~switches/s \u00f7 N.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(snitchos_task_main_runs_total[30s])",
          "legendFormat": "main",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "B",
          "expr": "rate(snitchos_task_idle_runs_total[30s])",
          "legendFormat": "idle",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "C",
          "expr": "rate(snitchos_task_task_a_runs_total[30s])",
          "legendFormat": "task_a",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        },
        {
          "refId": "D",
          "expr": "rate(snitchos_task_task_b_runs_total[30s])",
          "legendFormat": "task_b",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 34,
      "type": "stat",
      "title": "Tasks total",
      "description": "Count of tasks in the scheduler's table. Steady-state for v0.5: 4 (main, idle, task_a, task_b).",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 24
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_sched_tasks_total",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
