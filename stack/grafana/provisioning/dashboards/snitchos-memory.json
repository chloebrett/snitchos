  "title": "SnitchOS \u2014 Memory",
  "uid": "snitchos-memory",
  "id": null,
  "panels": [
    {
      "id": 7,
      "type": "stat",
      "title": "Frames in use",
      "description": "Physical 4 KiB frames currently allocated. Includes the reserved-at-boot regions (SBI firmware, kernel image, DTB) plus anything explicitly allocated since.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_frames_in_use",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "5s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Frames free",
