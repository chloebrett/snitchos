{
  "tags": [
    "snitchos",
    "itest"
  ],
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "annotations": {
    "list": []
  },
  "title": "SnitchOS — itest baselines",
  "uid": "snitchos-itest-baselines",
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Scenarios tracked",
      "description": "Number of distinct scenarios with a current baseline. Sourced from `cargo xtask itest --push-otlp`.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(snitchos_itest_baseline_runs)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Scenarios flaking (>0% rate)",
      "description": "Count of scenarios with at least one failure in their current baseline. 0 is good.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(snitchos_itest_baseline_failure_rate_ratio > 0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pending baselines",
      "description": "Scenarios whose current baseline is partial (run was interrupted). Promote or discard with `cargo xtask itest --promote-pending` / `--discard-pending`.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(snitchos_itest_baseline_partial_ratio == 1) OR on() vector(0)",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Hours since baseline updated",
      "description": "Wall-clock since the most-recently-recorded baseline. Stale baselines drift from current behaviour.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "(time() - max(snitchos_itest_baseline_recorded_at_seconds)) / 3600",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 168 },
              { "color": "red", "value": 720 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "value"
      }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Top 10 flake offenders (perceived rate)",
      "description": "Point-estimate failure rate (failures / runs). Compare against the Wilson lower / upper bounds beside this panel to see how confident we are in each rate.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, snitchos_itest_baseline_failure_rate_ratio)",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      }
    },
    {
      "id": 5,
      "type": "bargauge",
      "title": "Top 10 flake offenders (Wilson lower bound)",
      "description": "Lower bound of the Wilson-score 95% CI. \"How confident are we this scenario is at-least-this-flaky?\" High lower bound is the most worrying signal.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 8,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, snitchos_itest_baseline_wilson_lower_ratio)",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      }
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Top 10 flake offenders (Wilson upper bound)",
      "description": "Upper bound of the Wilson-score 95% CI. \"How flaky could this scenario plausibly be?\" High upper bound with a low lower bound = small sample, statistically inconclusive — run with --repeat to tighten the band.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 8,
        "x": 16,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, snitchos_itest_baseline_wilson_upper_ratio)",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.20 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      }
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "Top 10 slow scenarios (p95 duration)",
      "description": "p95 per-iteration wall-clock duration in milliseconds.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, snitchos_itest_baseline_p95_duration_ms_milliseconds)",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3000 },
              { "color": "red", "value": 10000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Scenarios flaking above 1%",
      "description": "Failure rate and Wilson 95% CI per scenario, filtered to rate > 1%. Sorted by Wilson lower bound descending — surfaces the most-confidently-flaky scenarios.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "targets": [
        {
          "refId": "rate",
          "expr": "snitchos_itest_baseline_failure_rate_ratio > 0.01",
          "legendFormat": "rate",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true,
          "format": "table"
        },
        {
          "refId": "lower",
          "expr": "snitchos_itest_baseline_wilson_lower_ratio",
          "legendFormat": "lower",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true,
          "format": "table"
        },
        {
          "refId": "upper",
          "expr": "snitchos_itest_baseline_wilson_upper_ratio",
          "legendFormat": "upper",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true,
          "format": "table"
        },
        {
          "refId": "runs",
          "expr": "snitchos_itest_baseline_runs",
          "legendFormat": "runs",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true,
          "format": "table"
        },
        {
          "refId": "failures",
          "expr": "snitchos_itest_baseline_failures_ratio",
          "legendFormat": "failures",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": { "byField": "scenario", "mode": "inner" }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true, "Time 2": true, "Time 3": true, "Time 4": true, "Time 5": true,
              "__name__ 1": true, "__name__ 2": true, "__name__ 3": true, "__name__ 4": true, "__name__ 5": true,
              "instance 1": true, "instance 2": true, "instance 3": true, "instance 4": true, "instance 5": true,
              "job 1": true, "job 2": true, "job 3": true, "job 4": true, "job 5": true
            },
            "renameByName": {
              "scenario": "scenario",
              "Value #rate": "rate",
              "Value #lower": "CI lower",
              "Value #upper": "CI upper",
              "Value #runs": "runs",
              "Value #failures": "failures"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "CI lower", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "rate" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CI lower" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "CI upper" },
            "properties": [
              { "id": "unit", "value": "percentunit" },
              { "id": "decimals", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failures" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "runs" },
            "properties": [
              { "id": "unit", "value": "short" },
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Failure rate over time (per scenario)",
      "description": "How the baseline failure rate has moved over time as you've pushed new baselines. Sudden jumps signal regressions; gradual drift signals a flake that hasn't been fixed.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_itest_baseline_failure_rate_ratio",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 5,
            "pointSize": 4,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Mean duration over time (per scenario)",
      "description": "Mean per-iteration wall-clock as the baseline has been updated over time.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 43
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_itest_baseline_mean_duration_ms_milliseconds",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 3,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "p95 duration over time (per scenario)",
      "description": "p95 per-iteration wall-clock as the baseline has been updated. Watch for tail growth even when the mean is steady.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 43
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_itest_baseline_p95_duration_ms_milliseconds",
          "legendFormat": "{{scenario}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "interval": "30s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 0,
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 3,
            "spanNulls": true
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 11,
      "type": "table",
      "title": "Failure buckets by scenario (cause-bucket breakdown)",
      "description": "Per-scenario failure counts split by classified cause-bucket (wedge / stalled / budget_exhausted / harness / unknown). Sorted by count so the worst scenario/bucket pairs float to the top. Turns 'X% flaky' into 'which scenario fails how'.",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 52
      },
      "targets": [
        {
          "refId": "A",
          "expr": "snitchos_itest_baseline_signature_ratio or snitchos_itest_baseline_signature",
          "format": "table",
          "instant": true,
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "job": true,
              "instance": true
            },
            "renameByName": {
              "scenario": "scenario",
              "signature": "bucket",
              "Value": "count"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [{ "field": "count", "desc": true }]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true },
          "decimals": 0
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "count", "desc": true }]
      }
    }
  ]
}
